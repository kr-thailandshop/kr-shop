<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#080d1a">
<title>BizCapture</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ════════════════════════════════════════
   DESIGN TOKENS
════════════════════════════════════════ */
:root {
  /* Dark base */
  --bg:       #080d1a;
  --bg2:      #0d1425;
  --surface:  rgba(255,255,255,.05);
  --surface2: rgba(255,255,255,.08);
  --glass:    rgba(255,255,255,.06);
  --glass-border: rgba(255,255,255,.10);

  /* Brand colors */
  --inc:    #00e5a0;
  --inc2:   #00c986;
  --inc-glow: rgba(0,229,160,.20);
  --exp:    #ff3d6b;
  --exp2:   #e52f5d;
  --exp-glow: rgba(255,61,107,.20);
  --acc:    #4f8dff;
  --acc2:   #2563eb;
  --acc-glow: rgba(79,141,255,.25);
  --gold:   #ffbb33;
  --gold-glow: rgba(255,187,51,.20);
  --purple: #9b6dff;

  /* Text */
  --t1: #f0f4ff;
  --t2: #8899bb;
  --t3: #4a5a7a;

  /* Radius */
  --r-sm: 10px;
  --r:    16px;
  --r-lg: 24px;

  /* Shadows */
  --shadow:    0 4px 24px rgba(0,0,0,.4);
  --shadow-lg: 0 8px 40px rgba(0,0,0,.6);

  /* Safe areas */
  --safe-t: env(safe-area-inset-top, 44px);
  --safe-b: env(safe-area-inset-bottom, 20px);
}

/* ════════════════════════════════════════
   RESET & BASE
════════════════════════════════════════ */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
html { height:100%; overflow:hidden; }
body {
  font-family: 'Noto Sans Thai', sans-serif;
  background: var(--bg);
  color: var(--t1);
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  /* Animated mesh gradient background */
  background-image:
    radial-gradient(ellipse 80% 50% at 20% -10%, rgba(79,141,255,.12) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 80% 110%, rgba(0,229,160,.08) 0%, transparent 60%),
    radial-gradient(ellipse 40% 30% at 50% 50%, rgba(155,109,255,.05) 0%, transparent 60%);
  background-attachment: fixed;
}

/* ════════════════════════════════════════
   SETUP SCREEN
════════════════════════════════════════ */
.setup {
  position: fixed; inset: 0; z-index: 600;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 24px;
  background: var(--bg);
  background-image:
    radial-gradient(ellipse 80% 50% at 20% -10%, rgba(79,141,255,.15) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 80% 110%, rgba(0,229,160,.1) 0%, transparent 60%);
}
.setup.gone { display: none; }

.setup-logo-wrap {
  width: 72px; height: 72px; border-radius: 22px;
  background: linear-gradient(135deg, var(--acc) 0%, var(--purple) 100%);
  display: flex; align-items: center; justify-content: center;
  font-size: 2rem; margin-bottom: 16px;
  box-shadow: 0 8px 32px rgba(79,141,255,.4);
}
.setup-title { font-size: 1.6rem; font-weight: 900; margin-bottom: 6px; }
.setup-title span { background: linear-gradient(135deg, var(--acc), var(--inc)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
.setup-sub { font-size: .85rem; color: var(--t2); text-align: center; line-height: 1.7; margin-bottom: 28px; }

.setup-card {
  background: var(--glass);
  border: 1px solid var(--glass-border);
  border-radius: var(--r-lg);
  padding: 20px;
  width: 100%; max-width: 400px;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.setup-step {
  display: flex; gap: 14px; align-items: flex-start;
  padding-bottom: 18px; margin-bottom: 18px;
  border-bottom: 1px solid var(--glass-border);
}
.setup-step:last-child { padding-bottom: 0; margin-bottom: 0; border-bottom: none; }

.step-num {
  width: 30px; height: 30px; border-radius: 50%;
  background: linear-gradient(135deg, var(--acc), var(--purple));
  color: #fff; font-weight: 800; font-size: .82rem;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  box-shadow: 0 4px 12px var(--acc-glow);
}
.step-body-title { font-size: .9rem; font-weight: 700; margin-bottom: 4px; }
.step-body-desc { font-size: .75rem; color: var(--t2); line-height: 1.6; margin-bottom: 8px; }

.setup-input {
  width: 100%;
  background: rgba(255,255,255,.06);
  border: 1.5px solid var(--glass-border);
  border-radius: var(--r-sm);
  padding: 11px 14px;
  color: var(--t1);
  font-family: 'Noto Sans Thai', sans-serif;
  font-size: .85rem;
  transition: border-color .2s, box-shadow .2s;
  margin-top: 6px;
}
.setup-input:focus { outline: none; border-color: var(--acc); box-shadow: 0 0 0 3px var(--acc-glow); }
.setup-input::placeholder { color: var(--t3); }

.link-btn {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 7px 14px; border-radius: 8px;
  background: var(--acc-glow); border: 1px solid rgba(79,141,255,.3);
  color: var(--acc); font-size: .78rem; font-weight: 600;
  cursor: pointer; text-decoration: none; transition: all .15s;
}
.link-btn:hover { background: rgba(79,141,255,.2); }

.setup-cta {
  width: 100%; max-width: 400px; margin-top: 16px;
  padding: 15px; border: none; border-radius: var(--r);
  background: linear-gradient(135deg, var(--inc), var(--acc));
  color: #fff; font-family: 'Noto Sans Thai', sans-serif;
  font-size: .95rem; font-weight: 800; cursor: pointer;
  box-shadow: 0 6px 24px var(--acc-glow);
  transition: all .2s; letter-spacing: .3px;
}
.setup-cta:hover { transform: translateY(-1px); box-shadow: 0 8px 32px var(--acc-glow); }
.setup-cta:active { transform: scale(.98); }

/* ════════════════════════════════════════
   APP SHELL
════════════════════════════════════════ */
.app { display: flex; flex-direction: column; height: 100%; overflow: hidden; }

/* ── TOP BAR ── */
.topbar {
  padding: calc(var(--safe-t) + 4px) 18px 12px;
  background: rgba(8,13,26,.8);
  border-bottom: 1px solid var(--glass-border);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  display: flex; align-items: center; gap: 12px;
  flex-shrink: 0; z-index: 10;
}
.brand-mark {
  width: 36px; height: 36px; border-radius: 11px;
  background: linear-gradient(135deg, var(--acc), var(--purple));
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem; flex-shrink: 0;
  box-shadow: 0 4px 14px var(--acc-glow);
}
.brand-text { font-weight: 900; font-size: .95rem; letter-spacing: .5px; }
.brand-text span { color: var(--inc); }

.sync-pill {
  display: flex; align-items: center; gap: 5px;
  padding: 4px 10px; border-radius: 20px;
  background: var(--glass); border: 1px solid var(--glass-border);
  font-size: .68rem; font-weight: 600; color: var(--t2);
  transition: all .3s;
}
.sync-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--t3); transition: all .3s; }
.sync-pill.ok { border-color: rgba(0,229,160,.2); color: var(--inc); }
.sync-pill.ok .sync-dot { background: var(--inc); box-shadow: 0 0 6px var(--inc); }
.sync-pill.syncing .sync-dot { background: var(--gold); animation: syncPulse .8s infinite; }
.sync-pill.err { border-color: rgba(255,61,107,.2); color: var(--exp); }
.sync-pill.err .sync-dot { background: var(--exp); }
@keyframes syncPulse { 0%,100%{opacity:1} 50%{opacity:.3} }

.topbar-right { margin-left: auto; display: flex; gap: 8px; align-items: center; }
.stat-chip {
  padding: 4px 10px; border-radius: 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: .72rem; font-weight: 700;
}
.stat-chip.i { background: var(--inc-glow); color: var(--inc); }
.stat-chip.e { background: var(--exp-glow); color: var(--exp); }

.icon-btn {
  width: 36px; height: 36px; border-radius: 10px;
  background: var(--glass); border: 1px solid var(--glass-border);
  color: var(--t2); cursor: pointer; font-size: 1rem;
  display: flex; align-items: center; justify-content: center;
  transition: all .15s;
}
.icon-btn:active { transform: scale(.92); background: var(--surface2); }

/* ── SCROLL BODY ── */
.body { flex: 1; overflow-y: auto; overflow-x: hidden; }
.body::-webkit-scrollbar { display: none; }

/* ── VIEWS ── */
.view { display: none; padding: 16px 16px calc(90px + var(--safe-b)); }
.view.on { display: block; }

/* ════════════════════════════════════════
   CAPTURE VIEW
════════════════════════════════════════ */

/* NET BALANCE CARD */
.balance-card {
  background: linear-gradient(135deg, rgba(79,141,255,.15) 0%, rgba(155,109,255,.12) 100%);
  border: 1px solid rgba(79,141,255,.2);
  border-radius: var(--r-lg);
  padding: 20px;
  margin-bottom: 14px;
  position: relative; overflow: hidden;
}
.balance-card::before {
  content: '';
  position: absolute; top: -30%; right: -10%;
  width: 180px; height: 180px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79,141,255,.12) 0%, transparent 70%);
  pointer-events: none;
}
.balance-lbl { font-size: .72rem; color: var(--t2); text-transform: uppercase; letter-spacing: 1.5px; font-weight: 600; margin-bottom: 6px; }
.balance-val {
  font-family: 'JetBrains Mono', monospace;
  font-size: 2rem; font-weight: 700;
  background: linear-gradient(135deg, #fff, var(--acc));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  margin-bottom: 12px;
}
.balance-row { display: flex; gap: 10px; }
.balance-item {
  flex: 1; background: rgba(255,255,255,.06); border-radius: var(--r-sm);
  padding: 10px 12px;
}
.balance-item-lbl { font-size: .68rem; color: var(--t2); margin-bottom: 4px; }
.balance-item-val { font-family: 'JetBrains Mono', monospace; font-size: .9rem; font-weight: 700; }
.balance-item-val.i { color: var(--inc); }
.balance-item-val.e { color: var(--exp); }

/* HERO DROP ZONE */
.hero {
  border-radius: var(--r-lg);
  margin-bottom: 12px;
  position: relative; overflow: hidden; cursor: pointer;
  min-height: 150px;
  background: linear-gradient(135deg, rgba(79,141,255,.18) 0%, rgba(37,99,235,.12) 100%);
  border: 1.5px dashed rgba(79,141,255,.35);
  transition: all .2s;
}
.hero:active { transform: scale(.99); }
.hero.has-img { border-style: solid; border-color: var(--acc-glow); background: none; }
.hero.scanning { border-color: var(--purple); border-style: solid; }
.hero.scanning::after {
  content: '';
  position: absolute; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--purple), transparent);
  animation: sweep 1.5s ease-in-out infinite;
}
@keyframes sweep { 0%{top:5%;opacity:0} 10%{opacity:1} 90%{opacity:1} 100%{top:95%;opacity:0} }

.hero-preview { width: 100%; max-height: 210px; object-fit: cover; border-radius: calc(var(--r-lg) - 1px); display: none; }
.hero.has-img .hero-preview { display: block; }
.hero.has-img .hero-inner { display: none; }
.hero-overlay {
  position: absolute; inset: 0; border-radius: var(--r-lg);
  background: rgba(0,0,0,.5); display: none;
  align-items: center; justify-content: center;
}
.hero.has-img:active .hero-overlay { display: flex; }

.hero-inner { padding: 22px 16px; display: flex; flex-direction: column; align-items: center; gap: 10px; }
.hero-icon-wrap {
  width: 60px; height: 60px; border-radius: 18px;
  background: rgba(79,141,255,.15); border: 1.5px solid rgba(79,141,255,.3);
  display: flex; align-items: center; justify-content: center; font-size: 1.8rem;
}
.hero-title { font-size: 1rem; font-weight: 800; }
.hero-sub { font-size: .78rem; color: var(--t2); text-align: center; line-height: 1.65; }
.hero-tags { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; }
.hero-tag {
  padding: 3px 10px; border-radius: 20px;
  background: rgba(255,255,255,.06); border: 1px solid var(--glass-border);
  font-size: .68rem; color: var(--t2);
}

/* METHODS */
.methods { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; margin-bottom: 12px; }
.meth {
  background: var(--glass); border: 1px solid var(--glass-border);
  border-radius: var(--r); padding: 12px 8px;
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  cursor: pointer; transition: all .15s;
  font-family: 'Noto Sans Thai', sans-serif;
  font-size: .72rem; color: var(--t2); font-weight: 600;
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
}
.meth:active { transform: scale(.94); }
.meth.cam:active  { background: var(--inc-glow); border-color: rgba(0,229,160,.3); color: var(--inc); }
.meth.up:active   { background: var(--acc-glow); border-color: rgba(79,141,255,.3); color: var(--acc); }
.meth.cl:active   { background: rgba(155,109,255,.15); border-color: rgba(155,109,255,.3); color: var(--purple); }
.meth.mic:active  { background: var(--gold-glow); border-color: rgba(255,187,51,.3); color: var(--gold); }
.meth-icon { font-size: 1.5rem; }

/* TEXT INPUT */
.txt-wrap { position: relative; margin-bottom: 12px; }
.txt-area {
  width: 100%;
  background: var(--glass);
  border: 1.5px solid var(--glass-border);
  border-radius: var(--r);
  padding: 13px 50px 13px 16px;
  color: var(--t1);
  font-family: 'Noto Sans Thai', sans-serif; font-size: .87rem;
  resize: none; min-height: 86px; line-height: 1.65;
  transition: all .2s;
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
}
.txt-area::placeholder { color: var(--t3); }
.txt-area:focus { outline: none; border-color: var(--acc); box-shadow: 0 0 0 3px var(--acc-glow); background: rgba(255,255,255,.07); }
.txt-send {
  position: absolute; bottom: 11px; right: 11px;
  width: 36px; height: 36px; border-radius: 11px; border: none;
  background: linear-gradient(135deg, var(--acc), var(--acc2));
  color: #fff; font-size: .95rem; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 14px var(--acc-glow); transition: all .15s;
}
.txt-send:active { transform: scale(.9); }

/* AI STATUS BAR */
.ai-bar {
  background: var(--gold-glow); border: 1px solid rgba(255,187,51,.2);
  border-radius: var(--r-sm); padding: 11px 14px; margin-bottom: 12px;
  display: none; align-items: center; gap: 10px;
  font-size: .8rem; color: var(--gold);
}
.ai-bar.on { display: flex; }
.ai-spin {
  width: 15px; height: 15px; border-radius: 50%;
  border: 2px solid rgba(255,187,51,.2); border-top-color: var(--gold);
  animation: spin .65s linear infinite; flex-shrink: 0;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* CONFIRM CARD */
.confirm {
  background: var(--glass);
  border: 1.5px solid var(--glass-border);
  border-radius: var(--r-lg); overflow: hidden;
  margin-bottom: 12px; display: none;
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  box-shadow: var(--shadow-lg);
}
.confirm.on { display: block; animation: popUp .22s cubic-bezier(.34,1.56,.64,1); }
@keyframes popUp { from{opacity:0;transform:translateY(12px) scale(.97)} to{opacity:1;transform:translateY(0) scale(1)} }

.cf-head {
  padding: 14px 16px;
  border-bottom: 1px solid var(--glass-border);
  display: flex; align-items: center; gap: 10px;
}
.cf-pill {
  padding: 4px 12px; border-radius: 20px;
  font-size: .72rem; font-weight: 800; flex-shrink: 0;
}
.cf-pill.i { background: var(--inc-glow); color: var(--inc); border: 1px solid rgba(0,229,160,.2); }
.cf-pill.e { background: var(--exp-glow); color: var(--exp); border: 1px solid rgba(255,61,107,.2); }
.cf-name { font-size: .92rem; font-weight: 700; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cf-amt { font-family: 'JetBrains Mono', monospace; font-size: 1.05rem; font-weight: 700; flex-shrink: 0; }
.cf-amt.i { color: var(--inc); }
.cf-amt.e { color: var(--exp); }

.cf-body { padding: 12px 16px; font-size: .8rem; color: var(--t2); line-height: 1.8; }
.cf-table { width: 100%; border-collapse: collapse; margin: 5px 0; }
.cf-table td { padding: 4px 4px; border-bottom: 1px solid var(--glass-border); }
.cf-table td:last-child { text-align: right; font-family: 'JetBrains Mono', monospace; color: var(--t1); font-weight: 600; }
.cf-multi { padding: 7px 12px; background: var(--gold-glow); border-radius: var(--r-sm); font-size: .76rem; color: var(--gold); font-weight: 700; margin-top: 6px; border: 1px solid rgba(255,187,51,.2); }

.cf-actions { display: flex; gap: 10px; padding: 12px 16px; border-top: 1px solid var(--glass-border); }
.cf-btn {
  flex: 1; padding: 12px; border: none; border-radius: var(--r-sm);
  font-family: 'Noto Sans Thai', sans-serif; font-size: .87rem; font-weight: 800;
  cursor: pointer; transition: all .15s; letter-spacing: .2px;
}
.cf-btn.save {
  background: linear-gradient(135deg, var(--inc), var(--inc2));
  color: #000; box-shadow: 0 4px 16px var(--inc-glow);
}
.cf-btn.save:active { transform: scale(.97); }
.cf-btn.cancel {
  background: rgba(255,255,255,.06); border: 1.5px solid var(--glass-border);
  color: var(--t2);
}
.cf-btn.cancel:active { background: rgba(255,61,107,.1); color: var(--exp); border-color: rgba(255,61,107,.2); }

/* SYNC BAR */
.sync-notice {
  padding: 10px 14px; border-radius: var(--r-sm); margin-bottom: 12px;
  font-size: .78rem; display: none; align-items: center; gap: 8px;
}
.sync-notice.on { display: flex; }
.sync-notice.ok { background: var(--inc-glow); color: var(--inc); border: 1px solid rgba(0,229,160,.2); }
.sync-notice.err { background: var(--exp-glow); color: var(--exp); border: 1px solid rgba(255,61,107,.2); }

/* ════════════════════════════════════════
   RECORDS VIEW
════════════════════════════════════════ */
.search-wrap {
  position: relative; margin-bottom: 10px;
}
.search-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: .9rem; }
.search-inp {
  width: 100%;
  background: var(--glass); border: 1.5px solid var(--glass-border);
  border-radius: var(--r); padding: 11px 14px 11px 38px;
  color: var(--t1); font-family: 'Noto Sans Thai', sans-serif; font-size: .87rem;
  transition: all .2s;
}
.search-inp:focus { outline: none; border-color: var(--acc); box-shadow: 0 0 0 3px var(--acc-glow); }
.search-inp::placeholder { color: var(--t3); }

.filters { display: flex; gap: 6px; overflow-x: auto; padding-bottom: 3px; margin-bottom: 14px; }
.filters::-webkit-scrollbar { display: none; }
.fc {
  padding: 6px 14px; border-radius: 20px;
  border: 1.5px solid var(--glass-border);
  background: var(--glass); color: var(--t2);
  font-size: .75rem; font-weight: 700; cursor: pointer;
  white-space: nowrap; flex-shrink: 0;
  font-family: 'Noto Sans Thai', sans-serif;
  transition: all .15s;
}
.fc.on { background: rgba(79,141,255,.15); border-color: rgba(79,141,255,.4); color: var(--acc); }

.day-label {
  font-size: .68rem; letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--t3); padding: 8px 2px 5px;
  font-family: 'JetBrains Mono', monospace; font-weight: 500;
}

.rec {
  background: var(--glass); border: 1px solid var(--glass-border);
  border-radius: var(--r); margin-bottom: 8px;
  display: flex; align-items: stretch; overflow: hidden; cursor: pointer;
  transition: all .15s; backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
}
.rec:active { transform: scale(.99); background: var(--surface2); }

.rec-thumb {
  width: 58px; flex-shrink: 0;
  background: rgba(255,255,255,.04);
  display: flex; align-items: center; justify-content: center; font-size: 1.6rem;
  overflow: hidden;
}
.rec-thumb img { width: 100%; height: 100%; object-fit: cover; }

.rec-bar { width: 3px; flex-shrink: 0; }
.rec-bar.i { background: linear-gradient(180deg, var(--inc), var(--inc2)); }
.rec-bar.e { background: linear-gradient(180deg, var(--exp), var(--exp2)); }

.rec-info { flex: 1; padding: 11px 12px; min-width: 0; }
.rec-name { font-size: .88rem; font-weight: 700; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.rec-tags { display: flex; gap: 5px; flex-wrap: wrap; align-items: center; }
.rtag {
  padding: 2px 8px; border-radius: 6px;
  font-size: .65rem; font-weight: 700;
}
.rtag.cat { background: var(--acc-glow); color: var(--acc); }
.rtag.src { background: rgba(255,255,255,.06); color: var(--t2); }
.rtag.img { background: var(--inc-glow); color: var(--inc); }
.rtag.syn { background: rgba(0,229,160,.08); color: var(--inc); border: 1px solid rgba(0,229,160,.15); }
.rec-note { font-size: .71rem; color: var(--t2); margin-top: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.rec-right { padding: 11px 14px; display: flex; flex-direction: column; align-items: flex-end; justify-content: center; gap: 4px; flex-shrink: 0; }
.rec-amt { font-family: 'JetBrains Mono', monospace; font-size: .88rem; font-weight: 700; white-space: nowrap; }
.rec-amt.i { color: var(--inc); }
.rec-amt.e { color: var(--exp); }
.rec-time { font-size: .65rem; color: var(--t3); font-family: 'JetBrains Mono', monospace; }

.empty { display: flex; flex-direction: column; align-items: center; padding: 52px 20px; gap: 12px; color: var(--t3); }
.empty-emoji { font-size: 3rem; opacity: .2; }

/* ════════════════════════════════════════
   REPORT VIEW
════════════════════════════════════════ */
.rcard {
  background: var(--glass); border: 1px solid var(--glass-border);
  border-radius: var(--r-lg); padding: 18px; margin-bottom: 12px;
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
}
.rcard-label { font-size: .7rem; text-transform: uppercase; letter-spacing: 2px; color: var(--t3); margin-bottom: 14px; font-weight: 700; }

.stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.stat-box {
  background: rgba(255,255,255,.04); border: 1px solid var(--glass-border);
  border-radius: var(--r-sm); padding: 13px;
}
.stat-box-lbl { font-size: .67rem; color: var(--t2); margin-bottom: 6px; text-transform: uppercase; letter-spacing: .8px; }
.stat-box-val { font-family: 'JetBrains Mono', monospace; font-size: 1rem; font-weight: 700; }

.cat-row { display: flex; align-items: center; gap: 9px; margin-bottom: 8px; }
.cat-name { font-size: .78rem; color: var(--t2); width: 68px; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cat-track { flex: 1; background: rgba(255,255,255,.06); border-radius: 4px; height: 8px; overflow: hidden; }
.cat-fill { height: 100%; border-radius: 4px; transition: width .6s cubic-bezier(.4,0,.2,1); }
.cat-amt { font-size: .7rem; font-family: 'JetBrains Mono', monospace; color: var(--t1); width: 62px; text-align: right; flex-shrink: 0; }

.ai-insight-box {
  background: rgba(255,255,255,.03); border: 1px solid var(--glass-border);
  border-radius: var(--r-sm); padding: 13px;
  font-size: .8rem; color: var(--t2); line-height: 1.85;
  white-space: pre-wrap; max-height: 190px; overflow-y: auto;
}
.ai-insight-box::-webkit-scrollbar { display: none; }

.report-btn {
  width: 100%; padding: 14px; border: none; border-radius: var(--r);
  background: linear-gradient(135deg, var(--acc), var(--purple));
  color: #fff; font-family: 'Noto Sans Thai', sans-serif;
  font-weight: 800; font-size: .9rem; cursor: pointer; margin-bottom: 10px;
  box-shadow: 0 6px 24px var(--acc-glow); transition: all .15s;
}
.report-btn:active { transform: scale(.98); }
.report-btn:disabled { opacity: .4; cursor: not-allowed; }

.export-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.export-btn {
  padding: 12px; border: 1.5px solid var(--glass-border);
  border-radius: var(--r-sm); background: var(--glass);
  color: var(--t2); font-family: 'Noto Sans Thai', sans-serif;
  font-size: .8rem; font-weight: 700; cursor: pointer; transition: all .15s;
}
.export-btn:active { border-color: var(--acc); color: var(--acc); background: var(--acc-glow); }

/* ════════════════════════════════════════
   BOTTOM NAV
════════════════════════════════════════ */
.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: rgba(8,13,26,.85);
  border-top: 1px solid var(--glass-border);
  backdrop-filter: blur(32px); -webkit-backdrop-filter: blur(32px);
  display: flex; padding-bottom: var(--safe-b);
  z-index: 50;
}
.nav-btn {
  flex: 1; padding: 10px 8px 8px;
  display: flex; flex-direction: column; align-items: center; gap: 4px;
  cursor: pointer; background: none; border: none; color: var(--t3);
  font-family: 'Noto Sans Thai', sans-serif; font-size: .71rem; font-weight: 700;
  transition: all .15s; position: relative;
}
.nav-btn.on { color: var(--acc); }
.nav-icon { font-size: 1.25rem; transition: transform .2s; }
.nav-btn.on .nav-icon { transform: translateY(-1px); }
.nav-indicator {
  position: absolute; bottom: calc(100% - 2px); left: 50%; transform: translateX(-50%);
  width: 20px; height: 3px; border-radius: 2px;
  background: var(--acc); display: none;
}
.nav-btn.on .nav-indicator { display: block; }

/* ════════════════════════════════════════
   MODALS (bottom sheets)
════════════════════════════════════════ */
.sheet-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,.6); z-index: 200;
  align-items: flex-end; justify-content: center;
  backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
}
.sheet-overlay.on { display: flex; }

.sheet {
  background: #111827;
  border: 1px solid var(--glass-border);
  border-radius: 24px 24px 0 0;
  width: 100%; max-width: 540px;
  padding: 16px 18px calc(18px + var(--safe-b));
  max-height: 88vh; overflow-y: auto;
  animation: sheetUp .25s cubic-bezier(.4,0,.2,1);
}
.sheet::-webkit-scrollbar { display: none; }
@keyframes sheetUp { from{transform:translateY(100%)} to{transform:translateY(0)} }
.sheet-handle {
  width: 40px; height: 4px; border-radius: 2px;
  background: var(--glass-border); margin: 0 auto 18px;
}
.sheet-title { font-size: 1.05rem; font-weight: 800; margin-bottom: 18px; }

/* DETAIL SHEET */
.detail-img { width: 100%; max-height: 230px; object-fit: cover; border-radius: var(--r); margin-bottom: 14px; display: none; }
.detail-img.on { display: block; }
.detail-head { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; }
.detail-pill { padding: 5px 13px; border-radius: 20px; font-size: .75rem; font-weight: 800; flex-shrink: 0; }
.detail-pill.i { background: var(--inc-glow); color: var(--inc); }
.detail-pill.e { background: var(--exp-glow); color: var(--exp); }
.detail-name-wrap { flex: 1; }
.detail-name { font-size: 1.1rem; font-weight: 800; margin-bottom: 3px; }
.detail-amt { font-family: 'JetBrains Mono', monospace; font-size: 1.3rem; font-weight: 700; }
.detail-amt.i { color: var(--inc); }
.detail-amt.e { color: var(--exp); }

.detail-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--glass-border); }
.detail-row:last-of-type { border-bottom: none; }
.dr-lbl { font-size: .8rem; color: var(--t2); }
.dr-val { font-size: .82rem; font-weight: 600; text-align: right; }

.detail-items-label { font-size: .7rem; color: var(--t3); text-transform: uppercase; letter-spacing: 1px; margin: 10px 0 6px; }
.detail-items-wrap { background: rgba(255,255,255,.03); border: 1px solid var(--glass-border); border-radius: var(--r-sm); overflow: hidden; }
.di { display: flex; padding: 9px 12px; border-bottom: 1px solid var(--glass-border); font-size: .8rem; }
.di:last-child { border-bottom: none; }
.di-name { flex: 1; }
.di-qty { color: var(--t2); margin: 0 10px; }
.di-price { font-family: 'JetBrains Mono', monospace; font-weight: 700; }

.raw-box { background: rgba(255,255,255,.03); border: 1px solid var(--glass-border); border-radius: var(--r-sm); padding: 10px; font-size: .73rem; color: var(--t2); line-height: 1.7; white-space: pre-wrap; margin-top: 10px; max-height: 100px; overflow-y: auto; }

.detail-btns { display: flex; gap: 8px; margin-top: 16px; }
.d-btn { flex: 1; padding: 12px; border-radius: var(--r-sm); border: none; font-family: 'Noto Sans Thai', sans-serif; font-size: .85rem; font-weight: 800; cursor: pointer; }
.d-btn.del { background: var(--exp-glow); color: var(--exp); border: 1px solid rgba(255,61,107,.2); }
.d-btn.close { background: linear-gradient(135deg, var(--acc), var(--acc2)); color: #fff; }

/* VOICE SHEET */
.voice-ring {
  width: 90px; height: 90px; border-radius: 50%;
  background: var(--gold-glow); border: 2px solid rgba(255,187,51,.3);
  display: flex; align-items: center; justify-content: center; font-size: 2.2rem;
  margin: 0 auto 14px;
  animation: vRing 1.3s ease-in-out infinite;
}
@keyframes vRing {
  0%,100% { box-shadow: 0 0 0 0 rgba(255,187,51,.3); transform: scale(1); }
  50%      { box-shadow: 0 0 0 16px rgba(255,187,51,0); transform: scale(1.03); }
}
.voice-hint { font-size: .78rem; color: var(--t2); text-align: center; line-height: 1.65; margin-bottom: 12px; }
.voice-box {
  background: rgba(255,255,255,.04); border: 1.5px solid var(--glass-border);
  border-radius: var(--r-sm); padding: 13px;
  font-size: .9rem; line-height: 1.7; min-height: 56px; margin: 12px 0;
}
.voice-cta { width: 100%; padding: 13px; background: linear-gradient(135deg, var(--gold), #ff9500); border: none; border-radius: var(--r-sm); color: #000; font-family: 'Noto Sans Thai', sans-serif; font-weight: 800; cursor: pointer; font-size: .9rem; margin-bottom: 8px; }
.voice-cancel { width: 100%; padding: 11px; background: transparent; border: 1.5px solid var(--glass-border); border-radius: var(--r-sm); color: var(--t2); font-family: 'Noto Sans Thai', sans-serif; cursor: pointer; }

/* SETTINGS SHEET */
.sett-label { font-size: .78rem; color: var(--t2); font-weight: 600; margin-bottom: 6px; }
.sett-input {
  width: 100%; background: rgba(255,255,255,.05); border: 1.5px solid var(--glass-border);
  border-radius: var(--r-sm); padding: 11px 14px; color: var(--t1);
  font-family: 'JetBrains Mono', monospace; font-size: .82rem; margin-bottom: 14px;
  transition: all .2s;
}
.sett-input:focus { outline: none; border-color: var(--acc); box-shadow: 0 0 0 3px var(--acc-glow); }
.sett-save { width: 100%; padding: 13px; background: linear-gradient(135deg, var(--inc), var(--acc)); border: none; border-radius: var(--r-sm); color: #fff; font-family: 'Noto Sans Thai', sans-serif; font-weight: 800; cursor: pointer; font-size: .88rem; margin-bottom: 8px; }
.sett-danger { width: 100%; padding: 11px; background: transparent; border: 1.5px solid rgba(255,61,107,.2); border-radius: var(--r-sm); color: var(--exp); font-family: 'Noto Sans Thai', sans-serif; cursor: pointer; font-size: .83rem; }

/* CAMERA */
.cam-screen { display: none; position: fixed; inset: 0; background: #000; z-index: 400; flex-direction: column; align-items: center; justify-content: center; gap: 20px; }
.cam-screen.on { display: flex; }
#camVideo { width: 100%; max-height: 72vh; object-fit: cover; }
.cam-ctrl { display: flex; gap: 18px; align-items: center; }
.cam-snap { width: 74px; height: 74px; border-radius: 50%; background: #fff; border: 4px solid rgba(255,255,255,.4); font-size: 1.9rem; cursor: pointer; box-shadow: 0 0 0 4px rgba(255,255,255,.15); transition: transform .1s; }
.cam-snap:active { transform: scale(.92); }
.cam-close-btn { width: 48px; height: 48px; border-radius: 50%; background: rgba(255,255,255,.12); border: none; color: #fff; font-size: 1.2rem; cursor: pointer; }

/* TOAST */
.toast {
  position: fixed; bottom: calc(78px + var(--safe-b) + 10px); left: 50%;
  transform: translateX(-50%) translateY(10px);
  background: rgba(17,24,39,.95); color: var(--t1);
  border: 1px solid var(--glass-border);
  padding: 10px 20px; border-radius: 12px;
  font-size: .82rem; font-weight: 600;
  opacity: 0; transition: all .25s; z-index: 500;
  pointer-events: none; white-space: nowrap;
  box-shadow: var(--shadow-lg);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
}
.toast.on { opacity: 1; transform: translateX(-50%) translateY(0); }

input[type=file] { display: none; }
</style>
</head>
<body>

<!-- ══ SETUP ══ -->
<div class="setup" id="setup">
  <div class="setup-logo-wrap">📊</div>
  <div class="setup-title">Biz<span>Capture</span></div>
  <div class="setup-sub">บันทึกรายรับรายจ่ายพร้อมหลักฐาน<br>ข้อมูลเก็บใน Google Sheets ของคุณเอง ปลอดภัย 100%</div>
  <div class="setup-card">
    <div class="setup-step">
      <div class="step-num">1</div>
      <div>
        <div class="step-body-title">สร้าง Google Sheet</div>
        <div class="step-body-desc">สร้างไฟล์ใหม่ใน Google Sheets แล้วคัดลอก URL มาวาง</div>
        <a class="link-btn" href="https://sheets.new" target="_blank">📄 สร้าง Google Sheet</a>
        <input class="setup-input" id="s_sheet" placeholder="https://docs.google.com/spreadsheets/d/...">
      </div>
    </div>
    <div class="setup-step">
      <div class="step-num">2</div>
      <div>
        <div class="step-body-title">ตั้งค่า Apps Script</div>
        <div class="step-body-desc">Extensions → Apps Script → วางโค้ด → Deploy → Copy URL</div>
        <button class="link-btn" onclick="copyScript()">📋 คัดลอกโค้ด</button>
        <input class="setup-input" id="s_api" placeholder="https://script.google.com/macros/s/...">
      </div>
    </div>
  </div>
  <button class="setup-cta" onclick="doSetup()">✓ เริ่มใช้งาน BizCapture</button>
  <p style="margin-top:14px;font-size:.73rem;color:var(--t3);text-align:center;max-width:340px;line-height:1.7">🔒 ข้อมูลเก็บใน Google Sheets ของคุณเอง ไม่มีการส่งข้อมูลไปที่อื่น</p>
</div>

<!-- ══ APP ══ -->
<div class="app" id="app" style="display:none">
  <!-- TOP BAR -->
  <div class="topbar">
    <div class="brand-mark">💼</div>
    <div>
      <div class="brand-text">Biz<span>Capture</span></div>
    </div>
    <div class="sync-pill" id="syncPill">
      <div class="sync-dot"></div>
      <span id="syncLabel">ออฟไลน์</span>
    </div>
    <div class="topbar-right">
      <div class="stat-chip i" id="tInc">฿0</div>
      <div class="stat-chip e" id="tExp">฿0</div>
      <button class="icon-btn" onclick="openSettings()">⚙️</button>
    </div>
  </div>

  <!-- BODY -->
  <div class="body" id="body">

    <!-- CAPTURE -->
    <div class="view on" id="v-cap">
      <!-- Balance Card -->
      <div class="balance-card">
        <div class="balance-lbl">คงเหลือสุทธิ</div>
        <div class="balance-val" id="balVal">฿0.00</div>
        <div class="balance-row">
          <div class="balance-item">
            <div class="balance-item-lbl">รายรับ</div>
            <div class="balance-item-val i" id="balInc">฿0</div>
          </div>
          <div class="balance-item">
            <div class="balance-item-lbl">รายจ่าย</div>
            <div class="balance-item-val e" id="balExp">฿0</div>
          </div>
          <div class="balance-item">
            <div class="balance-item-lbl">รายการ</div>
            <div class="balance-item-val" style="color:var(--acc)" id="balCount">0</div>
          </div>
        </div>
      </div>

      <div class="sync-notice" id="syncNotice"></div>

      <!-- Hero Drop Zone -->
      <div class="hero" id="hero" onclick="heroTap()">
        <img class="hero-preview" id="heroPrev" alt="">
        <div class="hero-overlay">
          <button onclick="clearHero(event)" style="padding:8px 18px;background:rgba(255,255,255,.9);border:none;border-radius:10px;font-weight:800;cursor:pointer;color:#000;font-size:.85rem">🔄 เปลี่ยนรูป</button>
        </div>
        <div class="hero-inner">
          <div class="hero-icon-wrap">📸</div>
          <div class="hero-title">ถ่าย / โยนไฟล์มาที่นี่</div>
          <div class="hero-sub">ใบเสร็จ · บิล · แคปแชท · สินค้า<br>AI อ่านและบันทึกให้ทันที พร้อมเก็บรูปหลักฐาน</div>
          <div class="hero-tags">
            <span class="hero-tag">🧾 ใบเสร็จ</span>
            <span class="hero-tag">📋 บิล</span>
            <span class="hero-tag">💬 แคปแชท</span>
            <span class="hero-tag">📦 สินค้า</span>
          </div>
        </div>
      </div>

      <!-- Methods -->
      <div class="methods">
        <button class="meth cam" onclick="openCam()"><span class="meth-icon">📷</span>กล้อง</button>
        <button class="meth up"  onclick="doUpload()"><span class="meth-icon">🖼️</span>อัปโหลด</button>
        <button class="meth cl"  onclick="doPaste()"><span class="meth-icon">📋</span>วาง</button>
        <button class="meth mic" onclick="openVoice()"><span class="meth-icon">🎤</span>เสียง</button>
      </div>

      <!-- Text input -->
      <div class="txt-wrap">
        <textarea class="txt-area" id="txtArea"
          placeholder="หรือพิมพ์ / วางข้อความ เช่น:&#10;• ซื้อวัตถุดิบ 1,200 บาท&#10;• copy ข้อความจาก Line ทั้งก้อนมาวาง&#10;กด Enter เพื่อส่ง"></textarea>
        <button class="txt-send" onclick="sendText()">➤</button>
      </div>

      <!-- AI bar -->
      <div class="ai-bar" id="aiBar">
        <div class="ai-spin"></div>
        <span id="aiMsg">AI กำลังวิเคราะห์...</span>
      </div>

      <!-- Confirm -->
      <div class="confirm" id="confirm">
        <div class="cf-head">
          <span class="cf-pill" id="cfPill">รายจ่าย</span>
          <span class="cf-name" id="cfName">—</span>
          <span class="cf-amt"  id="cfAmt">฿0</span>
        </div>
        <div class="cf-body" id="cfBody"></div>
        <div class="cf-actions">
          <button class="cf-btn cancel" onclick="dismissConfirm()">✕ ยกเลิก</button>
          <button class="cf-btn save"   onclick="saveRecord()">✓ บันทึก + Sync</button>
        </div>
      </div>
    </div>

    <!-- RECORDS -->
    <div class="view" id="v-rec">
      <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input class="search-inp" id="searchInp" placeholder="ค้นหารายการ..." oninput="renderRecords()">
      </div>
      <div class="filters">
        <button class="fc on" onclick="setFilter('all',this)">ทั้งหมด</button>
        <button class="fc" onclick="setFilter('inc',this)">💚 รายรับ</button>
        <button class="fc" onclick="setFilter('exp',this)">❤️ รายจ่าย</button>
        <button class="fc" onclick="setFilter('img',this)">📷 มีรูป</button>
        <button class="fc" onclick="setFilter('syn',this)">☁️ Synced</button>
      </div>
      <div id="recList"></div>
    </div>

    <!-- REPORT -->
    <div class="view" id="v-rep">
      <div class="rcard">
        <div class="rcard-label">สรุปการเงิน</div>
        <div class="stat-grid" id="statGrid"></div>
      </div>
      <div class="rcard">
        <div class="rcard-label">รายจ่ายตามหมวด</div>
        <div id="catChart"></div>
      </div>
      <div class="rcard">
        <div class="rcard-label">วิเคราะห์ธุรกิจโดย AI</div>
        <div class="ai-insight-box" id="aiInsight">— กดปุ่มด้านล่างเพื่อวิเคราะห์ —</div>
      </div>
      <button class="report-btn" id="repBtn" onclick="genReport()">🤖 วิเคราะห์ธุรกิจ</button>
      <div class="export-row">
        <button class="export-btn" onclick="doExportCSV()">📊 Export CSV</button>
        <button class="export-btn" onclick="openSheet()">📋 Google Sheets</button>
      </div>
    </div>

  </div>

  <!-- BOTTOM NAV -->
  <nav class="bottom-nav">
    <button class="nav-btn on" id="nb-cap" onclick="switchView('cap',this)">
      <div class="nav-indicator"></div>
      <span class="nav-icon">📥</span>บันทึก
    </button>
    <button class="nav-btn" id="nb-rec" onclick="switchView('rec',this)">
      <div class="nav-indicator"></div>
      <span class="nav-icon">🗂️</span>รายการ
    </button>
    <button class="nav-btn" id="nb-rep" onclick="switchView('rep',this)">
      <div class="nav-indicator"></div>
      <span class="nav-icon">📊</span>รายงาน
    </button>
  </nav>
</div>

<!-- CAMERA -->
<div class="cam-screen" id="camScreen">
  <video id="camVid" autoplay playsinline style="width:100%;max-height:72vh;object-fit:cover;"></video>
  <canvas id="camCvs" style="display:none"></canvas>
  <div class="cam-ctrl">
    <button class="cam-close-btn" onclick="closeCam()">✕</button>
    <button class="cam-snap" onclick="snap()">📸</button>
  </div>
</div>

<!-- VOICE SHEET -->
<div class="sheet-overlay" id="voiceSheet" onclick="closeSheetIfBg(event,'voiceSheet')">
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div class="voice-ring">🎤</div>
    <div class="voice-hint">พูดรายการได้เลย เช่น<br>"ขายสินค้าได้สองพัน" หรือ "ค่าน้ำมัน สี่ร้อยห้าสิบ"</div>
