<script id="asCode" type="text/plain">
function doPost(e) {
  try {
    const data = JSON.parse(e.postData.contents);
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    let sheet = ss.getSheetByName('รายการ');
    if (!sheet) {
      sheet = ss.insertSheet('รายการ');
      const headers = ['ID','วันที่','เวลา','ประเภท','ชื่อรายการ','หมวดหมู่','จำนวนเงิน','มีรูปหลักฐาน','แหล่งที่มา','หมายเหตุ','รายการสินค้า'];
      sheet.appendRow(headers);
      const hRange = sheet.getRange(1,1,1,headers.length);
      hRange.setFontWeight('bold').setBackground('#1a73e8').setFontColor('#ffffff');
      sheet.setFrozenRows(1);
    }
    const d = new Date(data.date);
    const tz = 'Asia/Bangkok';
    sheet.appendRow([
      data.id,
      Utilities.formatDate(d, tz, 'dd/MM/yyyy'),
      Utilities.formatDate(d, tz, 'HH:mm'),
      data.type === 'inc' ? 'รายรับ' : 'รายจ่าย',
      data.name, data.category, data.amount,
      data.hasImg ? '✅ มี' : '❌ ไม่มี',
      data.source, data.note || '',
      (data.items||[]).map(i=>`${i.name} x${i.qty} ฿${i.price}`).join(', ')
    ]);
    updateSummary(ss);
    return ContentService.createTextOutput(JSON.stringify({ok:true})).setMimeType(ContentService.MimeType.JSON);
  } catch(err) {
    return ContentService.createTextOutput(JSON.stringify({ok:false,error:err.message})).setMimeType(ContentService.MimeType.JSON);
  }
}
function updateSummary(ss) {
  let s = ss.getSheetByName('สรุป') || ss.insertSheet('สรุป');
  const rows = ss.getSheetByName('รายการ').getDataRange().getValues().slice(1);
  let inc=0, exp=0;
  rows.forEach(r=>{ r[3]==='รายรับ'? inc+=Number(r[6]||0) : exp+=Number(r[6]||0); });
  s.clearContents();
  const tz='Asia/Bangkok';
  s.appendRow(['อัปเดต', Utilities.formatDate(new Date(),tz,'dd/MM/yyyy HH:mm')]);
  s.appendRow(['รายรับ', inc]); s.appendRow(['รายจ่าย', exp]);
  s.appendRow(['กำไร', inc-exp]); s.appendRow(['รายการ', rows.length]);
}
function doGet(e) {
  return ContentService.createTextOutput(JSON.stringify({ok:true,status:'BizCapture API ready'})).setMimeType(ContentService.MimeType.JSON);
}
</script>

<script>
// ════════════ STATE ════════════
let recs = JSON.parse(localStorage.getItem('bc2_recs') || '[]');
let cfg  = JSON.parse(localStorage.getItem('bc2_cfg')  || 'null');
let fil  = 'all';
let pend = null;
let curImg = null;
let camStream = null;
let recog = null;
let vtxt = '';
let detId = null;

// ════════════ BOOT ════════════
(function(){
  if (cfg?.apiUrl) showApp();
  else document.getElementById('setup').classList.remove('gone');

  // drag-drop
  document.addEventListener('dragover', e=>e.preventDefault());
  document.addEventListener('drop', e=>{ e.preventDefault(); const f=e.dataTransfer.files[0]; if(f?.type.startsWith('image/')) readImg(f); });

  // paste
  document.addEventListener('paste', e=>{
    for(const it of e.clipboardData.items)
      if(it.type.startsWith('image/')){ e.preventDefault(); readImg(it.getAsFile()); return; }
  });

  // enter to send
  document.getElementById('txtArea')?.addEventListener('keydown', e=>{
    if(e.key==='Enter'&&!e.shiftKey){ e.preventDefault(); sendText(); }
  });
})();

function showApp(){
  document.getElementById('setup').classList.add('gone');
  document.getElementById('app').style.display = 'flex';
  updateStats(); renderRecords();
  setSyncUI(recs.some(r=>!r.synced) ? 'pending' : cfg?.apiUrl ? 'ok' : 'off');
}

// ════════════ SETUP ════════════
function doSetup(){
  const api = document.getElementById('s_api').value.trim();
  const sh  = document.getElementById('s_sheet').value.trim();
  if(!api){ toast('⚠️ กรุณากรอก Apps Script URL'); return; }
  cfg = { apiUrl:api, sheetUrl:sh, biz:'ธุรกิจของฉัน' };
  localStorage.setItem('bc2_cfg', JSON.stringify(cfg));
  showApp();
  toast('✅ ตั้งค่าสำเร็จ! เชื่อมต่อ Google Sheets แล้ว');
}

function copyScript(){
  const code = document.getElementById('asCode').textContent.trim();
  navigator.clipboard?.writeText(code).then(()=>toast('📋 คัดลอกโค้ดแล้ว!')).catch(()=>{
    const t=document.createElement('textarea'); t.value=code;
    document.body.appendChild(t); t.select(); document.execCommand('copy'); document.body.removeChild(t);
    toast('📋 คัดลอกแล้ว!');
  });
}

// ════════════ CAMERA ════════════
async function openCam(){
  if(/Mobi|Android|iPhone|iPad/i.test(navigator.userAgent)){ document.getElementById('camInp').click(); return; }
  try {
    camStream = await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment',width:{ideal:1920}}});
    document.getElementById('camVid').srcObject = camStream;
    document.getElementById('camScreen').classList.add('on');
  } catch { document.getElementById('camInp').click(); }
}
function snap(){
  const v=document.getElementById('camVid'), c=document.getElementById('camCvs');
  c.width=v.videoWidth; c.height=v.videoHeight;
  c.getContext('2d').drawImage(v,0,0);
  const url=c.toDataURL('image/jpeg',.88);
  curImg=url.split(',')[1];
  setHeroImg(url); closeCam(); analyzeImg(curImg);
}
function closeCam(){ if(camStream){camStream.getTracks().forEach(t=>t.stop());camStream=null;} document.getElementById('camScreen').classList.remove('on'); }

// ════════════ FILE ════════════
function doUpload(){ document.getElementById('fileInp').click(); }
function onFile(e){ const f=e.target.files[0]; if(f) readImg(f); e.target.value=''; }
function readImg(file){
  const r=new FileReader();
  r.onload=ev=>{ const b64=ev.target.result.split(',')[1]; curImg=b64; setHeroImg(ev.target.result); switchView('cap',document.getElementById('nb-cap')); analyzeImg(b64); };
  r.readAsDataURL(file);
}
function setHeroImg(src){ document.getElementById('heroPrev').src=src; document.getElementById('hero').classList.add('has-img'); }
function heroTap(){ if(!curImg) doUpload(); }
function clearHero(e){ e?.stopPropagation(); curImg=null; document.getElementById('hero').classList.remove('has-img','scanning'); document.getElementById('heroPrev').src=''; dismissConfirm(); }

// ════════════ PASTE ════════════
async function doPaste(){
  try {
    const items=await navigator.clipboard.read();
    for(const it of items){
      for(const type of it.types){
        if(type.startsWith('image/')){ readImg(await it.getType(type)); return; }
        if(type==='text/plain'){ const t=await(await it.getType(type)).text(); document.getElementById('txtArea').value=t; sendText(); return; }
      }
    }
  } catch { document.getElementById('txtArea').focus(); }
}

// ════════════ VOICE ════════════
function openVoice(){
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  if(!SR){ toast('กรุณาใช้ Chrome สำหรับฟีเจอร์เสียง'); return; }
  vtxt='';
  document.getElementById('voiceTxt').textContent='กำลังฟัง...';
  document.getElementById('voiceSheet').classList.add('on');
  recog=new SR(); recog.lang='th-TH'; recog.continuous=true; recog.interimResults=true;
  recog.onresult=e=>{ let t=''; for(const r of e.results) t+=r[0].transcript; document.getElementById('voiceTxt').textContent=t||'กำลังฟัง...'; if(e.results[e.results.length-1].isFinal) vtxt=t; };
  recog.start();
}
function submitVoice(){ if(recog){recog.stop();recog=null;} closeVoice(); const t=(vtxt||document.getElementById('voiceTxt').textContent).trim(); if(t&&t!=='กำลังฟัง...'){ document.getElementById('txtArea').value=t; sendText(); } }
function closeVoice(){ if(recog){recog.stop();recog=null;} document.getElementById('voiceSheet').classList.remove('on'); }

// ════════════ TEXT ANALYSIS ════════════
async function sendText(){
  const txt=document.getElementById('txtArea').value.trim();
  if(!txt) return;
  setAI(true,'AI กำลังอ่านข้อความ...');
  try {
    const r=await claude(null,`สกัดรายการรายรับ/รายจ่ายจากข้อความ ตอบ JSON เท่านั้น ห้าม backtick ห้ามข้อความอื่น
ถ้าหลายรายการส่ง array ถ้าเดียวส่ง object
{"type":"income|expense","name":"ชื่อ","amount":ตัวเลข,"category":"หมวด","note":"รายละเอียด","items":[{"name":"","qty":1,"price":0}],"source":"chat|text|bill"}
ข้อความ: ${txt}`);
    setAI(false); showConfirm(r,null); document.getElementById('txtArea').value='';
  } catch(e){ setAI(false); toast('❌ '+e.message); }
}

// ════════════ IMAGE ANALYSIS ════════════
async function analyzeImg(b64){
  document.getElementById('hero').classList.add('scanning');
  setAI(true,'AI กำลังอ่านรูปภาพ...');
  try {
    const r=await claude(b64,`วิเคราะห์รูปสกัดข้อมูลการเงิน ตอบ JSON เท่านั้น ห้าม backtick
{"type":"income|expense","name":"ชื่อหลัก","amount":ยอดรวม,"category":"หมวด","note":"รายละเอียด","items":[{"name":"","qty":1,"price":0}],"source":"receipt|bill|chat|image","raw_text":"ข้อความทั้งหมดในรูป"}
ถ้าเป็นใบเสร็จแยก items ถ้าไม่พบยอดใส่ 0`);
    document.getElementById('hero').classList.remove('scanning');
    setAI(false); showConfirm(r,b64);
  } catch(e){ document.getElementById('hero').classList.remove('scanning'); setAI(false); toast('❌ '+e.message); }
}

// ════════════ CLAUDE API ════════════
async function claude(imgB64, prompt){
  const content = imgB64
    ? [{type:'image',source:{type:'base64',media_type:'image/jpeg',data:imgB64}},{type:'text',text:prompt}]
    : prompt;
  const res=await fetch('https://api.anthropic.com/v1/messages',{
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content}]})
  });
  const d=await res.json();
  const txt=(d.content?.[0]?.text||'').replace(/```json|```/g,'').trim();
  try { return JSON.parse(txt); }
  catch { return {type:'expense',name:'ไม่ทราบ',amount:0,category:'อื่นๆ',note:txt,source:'unknown'}; }
}

// ════════════ CONFIRM ════════════
function showConfirm(data, imgB64){
  const entries=Array.isArray(data)?data:[data];
  const m=entries[0];
  pend={entries, imgB64: imgB64||curImg};
  const isI=m.type==='income';
  document.getElementById('cfPill').textContent = isI ? '+ รายรับ' : '- รายจ่าย';
  document.getElementById('cfPill').className = 'cf-pill '+(isI?'i':'e');
  document.getElementById('cfName').textContent = m.name||'?';
  document.getElementById('cfAmt').textContent = '฿'+fmt(m.amount);
  document.getElementById('cfAmt').className = 'cf-amt '+(isI?'i':'e');
  let html='';
  if(m.items?.length){ html+='<table class="cf-table">'; m.items.forEach(it=>html+=`<tr><td>${it.name}</td><td style="color:var(--t2)">${it.qty||1}×</td><td>฿${fmt(it.price||0)}</td></tr>`); html+='</table>'; }
  if(entries.length>1) html+=`<div class="cf-multi">⚡ พบ ${entries.length} รายการ — บันทึกทั้งหมด</div>`;
  if(m.category) html+=`<div>หมวด: <strong>${m.category}</strong></div>`;
  if(m.note) html+=`<div style="opacity:.7;margin-top:3px">${m.note.slice(0,100)}</div>`;
  document.getElementById('cfBody').innerHTML=html;
  document.getElementById('confirm').classList.add('on');
}
function dismissConfirm(){ document.getElementById('confirm').classList.remove('on'); pend=null; }

// ════════════ SAVE + SYNC ════════════
async function saveRecord(){
  if(!pend) return;
  const {entries,imgB64}=pend;
  const now=new Date().toISOString();
  entries.forEach(e=>{
    recs.push({
      id: Date.now()+'_'+Math.random().toString(36).slice(2,6),
      type: e.type==='income'?'inc':'exp',
      name: e.name||'?', amount: parseFloat(e.amount)||0,
      category: e.category||'ทั่วไป', note: e.note||'',
      items: e.items||[], raw: e.raw_text||'',
      source: e.source||'manual',
      imgB64: imgB64||null, date: now, synced: false
    });
  });
  save(); dismissConfirm(); clearHero();
  toast(`💾 บันทึก ${entries.length} รายการแล้ว — กำลัง Sync...`);
  await syncAll();
}

async function syncAll(){
  if(!cfg?.apiUrl) return;
  const us=recs.filter(r=>!r.synced);
  if(!us.length) return;
  setSyncUI('syncing');
  let ok=0;
  for(const r of us){
    try {
      await fetch(cfg.apiUrl,{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({id:r.id,date:r.date,type:r.type,name:r.name,category:r.category,amount:r.amount,hasImg:!!r.imgB64,source:r.source,note:r.note,items:r.items}),
        mode:'no-cors'});
      r.synced=true; ok++;
    } catch {}
  }
  save();
  if(ok===us.length){ setSyncUI('ok'); showNotice('ok',`☁️ Sync สำเร็จ ${ok} รายการ → Google Sheets`); }
  else { setSyncUI('err'); showNotice('err',`⚠️ Sync ไม่ได้ ${us.length-ok} รายการ — จะลองใหม่`); }
}

// ════════════ RENDER RECORDS ════════════
function renderRecords(){
  const list=document.getElementById('recList');
  const q=(document.getElementById('searchInp')?.value||'').toLowerCase();
  let data=[...recs].reverse();
  if(fil==='inc') data=data.filter(r=>r.type==='inc');
  else if(fil==='exp') data=data.filter(r=>r.type==='exp');
  else if(fil==='img') data=data.filter(r=>r.imgB64);
  else if(fil==='syn') data=data.filter(r=>r.synced);
  if(q) data=data.filter(r=>(r.name+r.category+r.note).toLowerCase().includes(q));

  if(!data.length){ list.innerHTML=`<div class="empty"><div class="empty-emoji">📁</div><p style="font-size:.85rem">${q?'ไม่พบรายการ':'ยังไม่มีรายการ<br>ถ่ายรูปหรือโยนไฟล์ด้านบน'}</p></div>`; return; }

  const groups={};
  data.forEach(r=>{ const d=new Date(r.date).toLocaleDateString('th-TH',{day:'numeric',month:'long',year:'numeric'}); if(!groups[d]) groups[d]=[]; groups[d].push(r); });

  const srcI={receipt:'🧾',bill:'📋',chat:'💬',image:'🖼️',manual:'✏️',text:'📝',unknown:'📄'};
  list.innerHTML=Object.entries(groups).map(([d,rs])=>
    `<div class="day-label">${d}</div>`+
    rs.map(r=>`
      <div class="rec" onclick="openDetail('${r.id}')">
        <div class="rec-thumb">${r.imgB64?`<img src="data:image/jpeg;base64,${r.imgB64}" loading="lazy">`:(r.type==='inc'?'💰':'💸')}</div>
        <div class="rec-bar ${r.type}"></div>
        <div class="rec-info">
          <div class="rec-name">${r.name}</div>
          <div class="rec-tags">
            <span class="rtag cat">${r.category}</span>
            <span class="rtag src">${srcI[r.source]||'📄'}</span>
            ${r.imgB64?'<span class="rtag img">📷</span>':''}
            ${r.synced?'<span class="rtag syn">☁️</span>':''}
          </div>
          ${r.note?`<div class="rec-note">${r.note.slice(0,55)}</div>`:''}
        </div>
        <div class="rec-right">
          <div class="rec-amt ${r.type}">${r.type==='inc'?'+':'−'}฿${fmt(r.amount)}</div>
          <div class="rec-time">${new Date(r.date).toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit'})}</div>
        </div>
      </div>`).join('')
  ).join('');
}

function setFilter(f,el){ fil=f; document.querySelectorAll('.fc').forEach(c=>c.classList.remove('on')); el.classList.add('on'); renderRecords(); }

// ════════════ DETAIL ════════════
function openDetail(id){
  const r=recs.find(x=>x.id==id); if(!r) return;
  detId=id;
  const di=document.getElementById('detImg');
  if(r.imgB64){ di.src='data:image/jpeg;base64,'+r.imgB64; di.classList.add('on'); } else di.classList.remove('on');
  const isI=r.type==='inc';
  const sl={receipt:'ใบเสร็จ',bill:'บิล',chat:'แชท',image:'รูปภาพ',manual:'กรอกเอง',text:'ข้อความ'};
  let h=`
    <div class="detail-head">
      <span class="detail-pill ${isI?'i':'e'}">${isI?'+ รายรับ':'- รายจ่าย'}</span>
      <div class="detail-name-wrap">
        <div class="detail-name">${r.name}</div>
        <div class="detail-amt ${isI?'i':'e'}">${isI?'+':'−'}฿${fmt(r.amount)}</div>
      </div>
    </div>
    <div class="detail-row"><span class="dr-lbl">วันที่/เวลา</span><span class="dr-val">${new Date(r.date).toLocaleString('th-TH')}</span></div>
    <div class="detail-row"><span class="dr-lbl">หมวดหมู่</span><span class="dr-val">${r.category}</span></div>
    <div class="detail-row"><span class="dr-lbl">แหล่งที่มา</span><span class="dr-val">${sl[r.source]||r.source}</span></div>
    <div class="detail-row"><span class="dr-lbl">รูปหลักฐาน</span><span class="dr-val" style="color:${r.imgB64?'var(--inc)':'var(--t3)'}">${r.imgB64?'✅ มีรูปแนบ':'❌ ไม่มีรูป'}</span></div>
    <div class="detail-row"><span class="dr-lbl">Google Sheets</span><span class="dr-val" style="color:${r.synced?'var(--inc)':'var(--gold)'}">${r.synced?'☁️ Sync แล้ว':'⏳ รอ Sync'}</span></div>
    ${r.note?`<div class="detail-row"><span class="dr-lbl">หมายเหตุ</span><span class="dr-val">${r.note}</span></div>`:''}
  `;
  if(r.items?.length){ h+=`<div class="detail-items-label">รายการสินค้า</div><div class="detail-items-wrap">`; r.items.forEach(it=>h+=`<div class="di"><span class="di-name">${it.name}</span><span class="di-qty">×${it.qty||1}</span><span class="di-price">฿${fmt(it.price||0)}</span></div>`); h+='</div>'; }
  if(r.raw) h+=`<div style="font-size:.7rem;color:var(--t3);margin-top:10px;margin-bottom:4px">ข้อความ AI อ่านได้จากรูป</div><div class="raw-box">${r.raw}</div>`;
  document.getElementById('detContent').innerHTML=h;
  document.getElementById('detailSheet').classList.add('on');
}
function closeDetail(){ document.getElementById('detailSheet').classList.remove('on'); detId=null; }
function doDelete(){ if(!detId||!confirm('ลบรายการนี้?')) return; recs=recs.filter(r=>r.id!=detId); save(); closeDetail(); toast('ลบแล้ว'); }

// ════════════ REPORT ════════════
function renderReport(){
  const inc=recs.filter(r=>r.type==='inc').reduce((s,r)=>s+r.amount,0);
  const exp=recs.filter(r=>r.type==='exp').reduce((s,r)=>s+r.amount,0);
  const syn=recs.filter(r=>r.synced).length;
  const wi=recs.filter(r=>r.imgB64).length;
  document.getElementById('statGrid').innerHTML=`
    <div class="stat-box"><div class="stat-box-lbl">รายรับ</div><div class="stat-box-val" style="color:var(--inc)">฿${fmtK(inc)}</div></div>
    <div class="stat-box"><div class="stat-box-lbl">รายจ่าย</div><div class="stat-box-val" style="color:var(--exp)">฿${fmtK(exp)}</div></div>
    <div class="stat-box"><div class="stat-box-lbl">กำไร/ขาดทุน</div><div class="stat-box-val" style="color:${inc>=exp?'var(--inc)':'var(--exp)'}">฿${fmtK(inc-exp)}</div></div>
    <div class="stat-box"><div class="stat-box-lbl">Synced/รวม</div><div class="stat-box-val" style="color:var(--acc)">${syn}/${recs.length}</div></div>
    <div class="stat-box"><div class="stat-box-lbl">มีรูปหลักฐาน</div><div class="stat-box-val" style="color:var(--gold)">${wi} รายการ</div></div>
    <div class="stat-box"><div class="stat-box-lbl">รอ Sync</div><div class="stat-box-val" style="color:${recs.length-syn?'var(--gold)':'var(--t3)'}">${recs.length-syn} รายการ</div></div>
  `;
  const cm={};
  recs.filter(r=>r.type==='exp').forEach(r=>cm[r.category]=(cm[r.category]||0)+r.amount);
  const mx=Math.max(...Object.values(cm),1);
  const clr=['var(--exp)','var(--acc)','var(--gold)','var(--inc)','var(--purple)','#ec4899'];
  document.getElementById('catChart').innerHTML=Object.entries(cm).sort((a,b)=>b[1]-a[1]).slice(0,6).map(([k,v],i)=>`
    <div class="cat-row">
      <div class="cat-name">${k}</div>
      <div class="cat-track"><div class="cat-fill" style="width:${(v/mx*100).toFixed(1)}%;background:${clr[i%clr.length]}"></div></div>
      <div class="cat-amt">฿${fmtK(v)}</div>
    </div>
  `).join('')||'<div style="color:var(--t3);font-size:.82rem">ยังไม่มีข้อมูลรายจ่าย</div>';
}

async function genReport(){
  const btn=document.getElementById('repBtn');
  btn.disabled=true; btn.textContent='⏳ กำลังวิเคราะห์...';
  document.getElementById('aiInsight').textContent='กำลังประมวลผล...';
  const sum={biz:cfg?.biz||'SME',inc:recs.filter(r=>r.type==='inc').reduce((s,r)=>s+r.amount,0),exp:recs.filter(r=>r.type==='exp').reduce((s,r)=>s+r.amount,0),count:recs.length,withImg:recs.filter(r=>r.imgB64).length,recent:recs.slice(-20).map(r=>({t:r.type,n:r.name,a:r.amount,c:r.category}))};
  try {
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:800,messages:[{role:'user',content:`วิเคราะห์ข้อมูล SME ไทย เป็นภาษาไทยตรงๆ มีประโยชน์จริง ให้คำแนะนำการเงิน การจัดเอกสารภาษี:\n${JSON.stringify(sum)}`}]})});
    const d=await res.json();
    document.getElementById('aiInsight').textContent=d.content?.[0]?.text||'—';
  } catch(e){ document.getElementById('aiInsight').textContent='เกิดข้อผิดพลาด: '+e.message; }
  btn.disabled=false; btn.textContent='🤖 วิเคราะห์ธุรกิจ';
}

function doExportCSV(){
  const rows=[['ID','วันที่','เวลา','ประเภท','ชื่อรายการ','หมวดหมู่','จำนวนเงิน','มีรูป','Synced','แหล่งที่มา','หมายเหตุ']];
  recs.forEach(r=>rows.push([r.id,new Date(r.date).toLocaleDateString('th-TH'),new Date(r.date).toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit'}),r.type==='inc'?'รายรับ':'รายจ่าย',r.name,r.category,r.amount,r.imgB64?'มี':'ไม่มี',r.synced?'Yes':'No',r.source,(r.note||'').replace(/,/g,';')]));
  const a=document.createElement('a');
  a.href='data:text/csv;charset=utf-8,\ufeff'+encodeURIComponent(rows.map(r=>r.map(v=>`"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n'));
  a.download=`bizcapture_${new Date().toISOString().split('T')[0]}.csv`; a.click();
  toast('✅ Export CSV สำเร็จ');
}

function openSheet(){ if(cfg?.sheetUrl) window.open(cfg.sheetUrl,'_blank'); else toast('ยังไม่ได้ตั้งค่า Sheet URL'); }

// ════════════ SETTINGS ════════════
function openSettings(){
  document.getElementById('sApi').value=cfg?.apiUrl||'';
  document.getElementById('sSheet').value=cfg?.sheetUrl||'';
  document.getElementById('sBiz').value=cfg?.biz||'';
  document.getElementById('settSheet').classList.add('on');
}
function saveSettings(){
  cfg={apiUrl:document.getElementById('sApi').value.trim(),sheetUrl:document.getElementById('sSheet').value.trim(),biz:document.getElementById('sBiz').value.trim()||'ธุรกิจ'};
  localStorage.setItem('bc2_cfg',JSON.stringify(cfg));
  document.getElementById('settSheet').classList.remove('on');
  toast('✅ บันทึกแล้ว'); if(cfg.apiUrl) syncAll();
}
function resetAll(){ if(!confirm('ล้างข้อมูลทั้งหมด?')) return; localStorage.clear(); location.reload(); }

// ════════════ VIEW ════════════
function switchView(v,el){
  document.querySelectorAll('.view').forEach(x=>x.classList.remove('on'));
  document.querySelectorAll('.nav-btn').forEach(x=>x.classList.remove('on'));
  document.getElementById('v-'+v).classList.add('on');
  el.classList.add('on');
  if(v==='rec') renderRecords();
  if(v==='rep') renderReport();
  document.getElementById('body').scrollTop=0;
}

// ════════════ UTILS ════════════
function fmt(n){ return Number(n||0).toLocaleString('th-TH',{minimumFractionDigits:2,maximumFractionDigits:2}); }
function fmtK(n){ return n>=10000?(n/1000).toFixed(1)+'K':fmt(n); }

function updateStats(){
  const inc=recs.filter(r=>r.type==='inc').reduce((s,r)=>s+r.amount,0);
  const exp=recs.filter(r=>r.type==='exp').reduce((s,r)=>s+r.amount,0);
  document.getElementById('tInc').textContent='฿'+fmtK(inc);
  document.getElementById('tExp').textContent='฿'+fmtK(exp);
  document.getElementById('balVal').textContent='฿'+fmt(inc-exp);
  document.getElementById('balInc').textContent='฿'+fmtK(inc);
  document.getElementById('balExp').textContent='฿'+fmtK(exp);
  document.getElementById('balCount').textContent=recs.length;
}

function save(){ localStorage.setItem('bc2_recs',JSON.stringify(recs)); updateStats(); renderRecords(); }

function setSyncUI(s){
  const p=document.getElementById('syncPill');
  const d=p.querySelector('.sync-dot');
  const lbl=document.getElementById('syncLabel');
  p.className='sync-pill';
  if(s==='ok'){ p.classList.add('ok'); lbl.textContent='Synced'; }
  else if(s==='syncing'){ p.classList.add('syncing'); lbl.textContent='Syncing...'; }
  else if(s==='err'){ p.classList.add('err'); lbl.textContent='Sync Error'; }
  else if(s==='pending'){ lbl.textContent='รอ Sync'; }
  else { lbl.textContent='ออฟไลน์'; }
}

function showNotice(type,msg){ const el=document.getElementById('syncNotice'); el.className='sync-notice on '+type; el.textContent=msg; setTimeout(()=>el.classList.remove('on'),4000); }

function closeSheetIfBg(e,id){ if(e.target===document.getElementById(id)) document.getElementById(id).classList.remove('on'); }

function toast(msg){ const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('on'); setTimeout(()=>t.classList.remove('on'),3000); }
</script>
